{
  "name": "assurance-playbooks",
  "version": "0.1.0",
  "description": "Open assurance methods for AI-built codebases and agentic delivery systems",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE-CODE",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=22.12"
  },
  "bin": {
    "assurance-playbooks": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schemas.js",
    "./catalog.json": "./dist/catalog.json"
  },
  "files": [
    "content",
    "dist",
    "LICENSE-CODE",
    "LICENSE-CONTENT",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node dist/cli.js export content --format json --out dist/catalog.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --diagnostic-level=error .",
    "test": "vitest run src",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "prepack": "pnpm check"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.2.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
